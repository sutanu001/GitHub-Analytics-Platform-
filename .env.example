# Server Configuration
PORT=5000
JWT_SECRET=github_analytics_super_secret_key_123

# Mock Mode Configuration
# Set to 'false' (or remove) to run the real GitHub OAuth login flow (requires credentials below)
MOCK_AUTH=true
# Set to 'false' to disable mock simulations and run real database analysis (requires running PostgreSQL)
MOCK_DATA=true



# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/github_analytics

# Firebase Client Configuration (Frontend)
# Register a web app in your Firebase Console > Project Settings to find these values
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Firebase Server Configuration (Backend)
# Generate a service account private key JSON in Firebase Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json


# Google Gemini API Key
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
